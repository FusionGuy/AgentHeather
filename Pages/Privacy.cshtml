@*
    =====================================================================
    File: Pages/Privacy.cshtml

    Purpose:
        Static placeholder privacy-policy page linked from the footer and
        the top navigation. No model data is required – the view simply
        renders the page title and a stub paragraph.

    Model:
        PrivacyModel (Pages/Privacy.cshtml.cs) – empty OnGet handler.
    =====================================================================
*@
@page
@model PrivacyModel
@{
    ViewData["Title"] = "Privacy Policy";
}
<h1>@ViewData["Title"]</h1>

<p>Use this page to detail your site's privacy policy.</p>
